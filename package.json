{
  "name": "servicenow-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for ServiceNow — 93 tools across incidents, changes, catalog, CMDB, users, knowledge, workflows, and more. Multi-instance support.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "start:http": "bun run src/http.ts",
