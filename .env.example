# ServiceNow MCP Server Configuration
# Copy this to .env and fill in your values
#
# NOTE: For multi-instance support, use config/servicenow-instances.json instead.
# See config/servicenow-instances.example.json for the template.
# When a JSON config file is present, the env vars below are ignored.

# ── Instance ──────────────────────────────────────────────
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com

# ── Authentication ────────────────────────────────────────
# Auth type: "basic" or "oauth"
SERVICENOW_AUTH_TYPE=basic

# Basic auth
SERVICENOW_USERNAME=your-username
SERVICENOW_PASSWORD=your-password

# OAuth 2.0 (only needed if AUTH_TYPE=oauth)
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
# OAuth can also use username/password for resource owner grant

# ── Tool Packages (optional) ─────────────────────────────
# Limit which tools are exposed. Options:
# full (default), service_desk, change_coordinator, catalog_builder,
# knowledge_author, platform_developer, system_admin, agile
# SN_TOOL_PACKAGE=full

# ── Debug ─────────────────────────────────────────────────
# SN_DEBUG=false

# ── HTTP Transport (optional) ────────────────────────────
# SN_HTTP_PORT=3000
# SN_HTTP_HOST=127.0.0.1
